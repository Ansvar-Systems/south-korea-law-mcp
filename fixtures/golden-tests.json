      }
    },
    {
      "id": "kr-010",
      "category": "eu_cross_reference",
      "description": "Cross-reference lookup for PIPA — returns gracefully when corpus not yet ingested",
      "tool": "get_provision_eu_basis",
      "input": {
        "law_identifier": "개인정보 보호법"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "kr-011",
      "category": "negative_test",
      "description": "Non-existent law identifier returns graceful error or empty result",
      "tool": "get_provision",
      "input": {
        "law_identifier": "존재하지 않는 법률 9999",
        "article": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
