{
  "$schema": "./golden-tests.schema.json",
  "version": "1.0",
  "mcp_name": "South Korea Law MCP",
  "description": "Golden contract tests for the South Korea Law MCP. Note: article retrieval, search, and cross-reference tests use handles_gracefully because the DB corpus is pending full ingestion.",
  "tests": [
    {
      "id": "kr-001",
      "category": "article_retrieval",
      "description": "Retrieve Article 1 of PIPA (개인정보 보호법) — returns gracefully when corpus not yet ingested",
      "tool": "get_provision",
      "input": {
        "law_identifier": "개인정보 보호법",
        "article": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "kr-002",
      "category": "article_retrieval",
      "description": "Retrieve Article 15 of PIPA — returns gracefully when corpus not yet ingested",
      "tool": "get_provision",
      "input": {
        "law_identifier": "개인정보 보호법",
        "article": "15"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "kr-003",
      "category": "article_retrieval",
      "description": "Retrieve Article 17 of PIPA — returns gracefully when corpus not yet ingested",
      "tool": "get_provision",
      "input": {
        "law_identifier": "개인정보 보호법",
        "article": "17"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "kr-004",
      "category": "article_retrieval",
      "description": "Retrieve Article 1 of the Network Act (정보통신망법) — returns gracefully when corpus not yet ingested",
      "tool": "get_provision",
      "input": {
        "law_identifier": "정보통신망 이용촉진 및 정보보호 등에 관한 법률",
        "article": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
      "id": "kr-005",
      "category": "search",
      "description": "Full-text search for '개인정보' (personal information) — returns gracefully when corpus not yet ingested",
      "tool": "search_legislation",
      "input": {
        "query": "개인정보"
      },
      "assertions": {
        "result_not_empty": true,
        "handles_gracefully": true
      }
    },
    {
      "id": "kr-006",
      "category": "search",
      "description": "Full-text search for '사이버' (cyber) — returns gracefully when corpus not yet ingested",
      "tool": "search_legislation",
      "input": {
        "query": "사이버"
      },
      "assertions": {
        "result_not_empty": true,
        "handles_gracefully": true
      }
    },
    {
      "id": "kr-007",
      "category": "search",
      "description": "Full-text search for 'personal information' in English — returns gracefully when corpus not yet ingested",
      "tool": "search_legislation",
      "input": {
        "query": "personal information"
      },
      "assertions": {
        "result_not_empty": true,
        "handles_gracefully": true
      }
    },
    {
      "id": "kr-008",
      "category": "citation_roundtrip",
      "description": "Citation for PIPA Article 1 — returns gracefully when corpus not yet ingested",
      "tool": "get_provision",
      "input": {
        "law_identifier": "개인정보 보호법",
        "article": "1"
      },
      "assertions": {
        "handles_gracefully": true
      }
    },
    {
